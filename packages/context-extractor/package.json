{
    "name": "@salesforce-ux/context-extractor",
    "version": "1.0.8-internal",
    "private": true,
    "type": "module",
    "description": "SLDS Context Extractor by scanning core repo",
    "main": "build/index.js",
    "scripts": {
        "test": "echo \"Error: no test specified\"",
        "build": "gulp build",
